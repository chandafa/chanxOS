<?xml version="1.0" encoding="UTF-8"?>
<channel name="xfwm4" version="1.0">
  <property name="general" type="empty">
    <!-- Theme -->
    <property name="theme"                type="string"  value="ChanxGlass"/>
    <property name="title_font"           type="string"  value="Inter Semi-Bold 10"/>
    <!-- macOS-style: close,minimize,maximize on LEFT -->
    <property name="button_layout"        type="string"  value="C|MH"/>
    <property name="workspace_count"      type="int"     value="1"/>

    <!-- Compositing (built-in xfwm4) -->
    <property name="use_compositing"      type="bool"    value="true"/>
    <property name="frame_opacity"        type="int"     value="90"/>
    <property name="inactive_opacity"     type="int"     value="95"/>
    <property name="shadow_opacity"       type="int"     value="0"/>

    <!-- Window behavior -->
    <property name="tile_on_move"         type="bool"    value="true"/>
    <property name="snap_to_border"       type="bool"    value="true"/>
    <property name="snap_to_windows"      type="bool"    value="true"/>
    <property name="snap_width"           type="int"     value="10"/>
    <property name="wrap_windows"         type="bool"    value="false"/>
    <property name="wrap_workspaces"      type="bool"    value="false"/>
    <property name="show_dock_shadow"     type="bool"    value="false"/>

    <!-- Window decorations -->
    <property name="title_alignment"      type="string"  value="center"/>
    <property name="borderless_maximize"  type="bool"    value="true"/>
    <property name="titleless_maximize"   type="bool"    value="false"/>

    <!-- Animations -->
    <property name="activate_action"      type="string"  value="bring"/>
    <property name="double_click_action"  type="string"  value="maximize"/>
    <property name="easy_click"           type="string"  value="Alt"/>
  </property>
</channel>
