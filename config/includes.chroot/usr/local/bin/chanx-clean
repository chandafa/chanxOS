#!/usr/bin/env bash
# chanxOS Cache & Junk Cleaner
set -euo pipefail

CYAN='\033[1;36m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'
step() { echo -e "\n${CYAN}▶  $1${RESET}"; }
ok()   { echo -e "${GREEN}✓  $1${RESET}"; }

step "Menghapus paket tidak terpakai..."
sudo apt autoremove -y 2>&1 | tail -3
ok "autoremove selesai"

step "Membersihkan cache apt..."
sudo apt autoclean 2>&1 | tail -2
ok "autoclean selesai"

step "Membersihkan log journald (simpan 7 hari)..."
sudo journalctl --vacuum-time=7d 2>/dev/null | tail -2 || true
ok "journald selesai"

step "Menghapus file temp user..."
rm -rf "${HOME}/.cache/thumbnails/fail/" 2>/dev/null || true
ok "Temp files selesai"

# Show freed space
FREE=$(df -h / | awk 'NR==2{print $4}')
echo ""
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${GREEN}  Pembersihan selesai! Ruang tersedia: ${FREE}${RESET}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
