#!/usr/bin/env bash
# chanxOS DevPack Installer
set -euo pipefail

CYAN='\033[1;36m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'
step() { echo -e "\n${CYAN}▶  $1${RESET}"; }
ok()   { echo -e "${GREEN}✓  $1${RESET}"; }

install_web() {
  step "Menginstall Web Developer Pack..."
  sudo apt update
  sudo apt install -y git curl wget nodejs npm build-essential
  ok "Web Developer Pack selesai (git, nodejs, npm, build-essential)"
}

install_laravel() {
  step "Menginstall Laravel Pack..."
  sudo apt update
  sudo apt install -y php php-cli php-mbstring php-xml php-curl php-zip php-mysql composer mariadb-client
  ok "Laravel Pack selesai (php, composer, mariadb-client)"
}

install_rust() {
  step "Menginstall Rust Pack..."
  sudo apt update
  sudo apt install -y build-essential curl ca-certificates
  echo ""
  echo -e "${YELLOW}Rustup akan didownload dan diinstall. Ikuti instruksi di layar.${RESET}"
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
  ok "Rust Pack selesai"
}

install_python() {
  step "Menginstall Python Dev Pack..."
  sudo apt update
  sudo apt install -y python3 python3-pip python3-venv python3-dev build-essential
  pip3 install --user pipx 2>/dev/null || true
  ok "Python Dev Pack selesai (python3, pip, venv)"
}

install_student() {
  step "Menginstall Student Pack..."
  sudo apt update
  sudo apt install -y libreoffice evince flameshot gparted file-roller unzip zip
  ok "Student Pack selesai (libreoffice, evince, flameshot, gparted)"
}

# ── GUI mode ─────────────────────────────────────────────────────
if command -v zenity >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]] && [[ "${1:-}" == "" ]]; then
  CHOICE=$(zenity --list \
    --title="chanxOS DevPack Installer" \
    --window-icon=chanxos-devpack \
    --width=620 --height=380 \
    --text="<b>chanxOS DevPack Installer</b>
Pilih paket yang ingin diinstall:" \
    --column="ID" --column="Pack" --column="Isi Paket" \
    --hide-column=1 --print-column=1 \
    "web"     "  Web Developer"    "Git, Node.js, npm, build-essential" \
    "laravel" "  Laravel / PHP"    "PHP, Composer, MariaDB client" \
    "rust"    "  Rust Developer"   "Rustup, Cargo, build tools" \
    "python"  "  Python Dev"       "Python 3, pip, venv, dev headers" \
    "student" "  Student Pack"     "LibreOffice, PDF reader, Flameshot, GParted" \
    2>/dev/null) || exit 0

  TERM_CMD="chanx-devpack --${CHOICE}"
  if command -v xfce4-terminal >/dev/null 2>&1; then
    xfce4-terminal --title="chanxOS DevPack" --hide-menubar \
      -e "bash -lc '${TERM_CMD}; echo; read -rp \"Tekan Enter untuk menutup...\" _'" &
  else
    x-terminal-emulator -T "chanxOS DevPack" \
      -e "bash -lc '${TERM_CMD}; echo; read -rp \"Tekan Enter untuk menutup...\" _'" &
  fi
  exit 0
fi

# ── CLI mode ─────────────────────────────────────────────────────
case "${1:-}" in
  --web)     install_web     ;;
  --laravel) install_laravel ;;
  --rust)    install_rust    ;;
  --python)  install_python  ;;
  --student) install_student ;;
  *)
    echo "chanxOS DevPack Installer"
    echo "========================="
    echo "Pilihan:"
    echo "  --web      Web Developer (git, nodejs, npm)"
    echo "  --laravel  Laravel (php, composer, mariadb)"
    echo "  --rust     Rust (rustup, cargo)"
    echo "  --python   Python Dev (python3, pip, venv)"
    echo "  --student  Student (libreoffice, evince, flameshot)"
    echo ""
    read -rp "Pilih [web/laravel/rust/python/student]: " OPT
    case "$OPT" in
      web)     install_web     ;;
      laravel) install_laravel ;;
      rust)    install_rust    ;;
      python)  install_python  ;;
      student) install_student ;;
      *)       echo "Pilihan tidak valid"; exit 1 ;;
    esac
    ;;
esac
