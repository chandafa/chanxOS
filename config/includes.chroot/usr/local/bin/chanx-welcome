#!/usr/bin/env bash
    set -euo pipefail

    open_term() {
      local cmd="$1"
      if command -v x-terminal-emulator >/dev/null 2>&1; then
        x-terminal-emulator -T "chanxOS" -e bash -lc "$cmd; echo; read -rp 'Press Enter to close...'"
      else
        bash -lc "$cmd"
      fi
    }

    show_menu() {
      zenity --list         --title="chanxOS Welcome Center"         --window-icon="chanxos-welcome"         --text="<span size='x-large' weight='bold'>Welcome to chanxOS</span>
Clean, calm, and developer-friendly Linux."         --column="Action" --column="Description"         "System Info" "Show system information"         "Update System" "Run software update"         "Install DevPack" "Install optional developer tools"         "Study Mode" "Start a 25-minute focus timer"         "Open Learning Hub" "Browse learning notes"         "Open Terminal" "Launch xfce4-terminal"         "Install chanxOS" "Open installer"         "Close" "Exit"         --width=760 --height=420
    }

    if command -v zenity >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
      while true; do
        choice=$(show_menu) || exit 0
        case "$choice" in
          "System Info"*) open_term "chanx-info" ;;
          "Update System"*) open_term "chanx-update" ;;
          "Install DevPack"*) open_term "chanx-devpack" ;;
          "Study Mode"*) open_term "chanx-study-mode 25" ;;
          "Open Learning Hub"*) xdg-open "$HOME/ChanxOS-Learning" >/dev/null 2>&1 || true ;;
          "Open Terminal"*) xfce4-terminal >/dev/null 2>&1 & ;;
          "Install chanxOS"*) chanx-install ;;
          *) exit 0 ;;
        esac
      done
    else
      cat <<'TXT'
Welcome to chanxOS
Commands: chanx-info, chanx-update, chanx-clean, chanx-devpack, chanx-study-mode 25, chanx-install
TXT
    fi
