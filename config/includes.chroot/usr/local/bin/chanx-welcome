#!/usr/bin/env bash
# chanxOS Welcome Center
set -euo pipefail

VERSION="0.1 Alpha"
CODENAME="Glass Fox"

open_term() {
  local cmd="$1"
  local title="${2:-chanxOS}"
  if command -v xfce4-terminal >/dev/null 2>&1; then
    xfce4-terminal --title="$title" --hide-menubar \
      -e "bash -lc \"$cmd; echo; read -rp 'Tekan Enter untuk menutup...' _\"" &
  else
    bash -lc "$cmd" || true
  fi
}

show_sysinfo() {
  K="$(uname -r)"
  H="$(hostname)"
  U="$(whoami)"
  UP="$(uptime -p 2>/dev/null | sed 's/up //' || echo 'N/A')"
  SH="${SHELL##*/}"
  MEM="$(free -h | awk '/^Mem:/{print $3 " / " $2}')"
  DSK="$(df -h / | awk 'NR==2{print $3 " / " $2}')"
  zenity --info --title="chanxOS System Info" \
    --window-icon="chanxos-logo" --width=480 \
    --text="<span font_family='monospace' size='10000'><b>chanxOS ${VERSION} — ${CODENAME}</b>

  Kernel   :  ${K}
  Hostname :  ${H}
  User     :  ${U}
  Shell    :  ${SH}
  Uptime   :  ${UP}
  Memory   :  ${MEM}
  Disk (/) :  ${DSK}</span>" 2>/dev/null || true
}

show_menu() {
  zenity --list \
    --title="chanxOS Welcome Center" \
    --window-icon="chanxos-welcome" \
    --width=700 --height=500 \
    --text="<span size='large' weight='bold'>Selamat datang di chanxOS ${VERSION}</span>
<span color='#4a7090'>Clean  ·  Minimal  ·  Liquid Glass  ·  Developer-Friendly</span>" \
    --column="" --column="Fitur" --column="Deskripsi" \
    --hide-column=1 --print-column=1 \
    "sysinfo"   "  System Info"         "Kernel, RAM, disk, uptime" \
    "update"    "  Update Sistem"       "Update semua paket" \
    "devpack"   "  DevPack Installer"   "Install tools developer" \
    "study"     "  Study Mode"          "Timer Pomodoro 25 menit" \
    "focus"     "  Focus Mode"          "Sembunyikan panel dan notifikasi" \
    "hud"       "  HUD Overlay"         "Info real-time di atas wallpaper" \
    "note"      "  QuickNote"           "Buka catatan cepat" \
    "snap"      "  Screenshot"          "Ambil screenshot layar" \
    "glass"     "  Glass Manager"       "Atur level efek liquid glass" \
    "theme"     "  Theme Switcher"      "Light / Dark / Auto mode" \
    "learning"  "  Learning Hub"        "Buka folder catatan belajar" \
    "terminal"  "  Terminal"            "Buka xfce4-terminal" \
    "install"   "  Install chanxOS"     "Install chanxOS ke hard disk" \
    "close"     "  Tutup"               "Keluar dari Welcome Center" \
    2>/dev/null
}

if command -v zenity >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
  while true; do
    CHOICE=$(show_menu) || break
    case "$CHOICE" in
      sysinfo)   show_sysinfo ;;
      update)    open_term "chanx-update" "chanxOS Update" ;;
      devpack)   chanx-devpack & ;;
      study)     open_term "chanx-study-mode 25" "chanxOS Study Mode" ;;
      focus)     chanx-focus toggle & ;;
      hud)       chanx-hud & ;;
      note)      chanx-quicknote & ;;
      snap)      chanx-snap & ;;
      glass)     chanx-glass & ;;
      theme)     chanx-theme & ;;
      learning)  xdg-open "${HOME}/ChanxOS-Learning" 2>/dev/null || \
                   thunar "${HOME}/ChanxOS-Learning" 2>/dev/null || true ;;
      terminal)  xfce4-terminal --hide-menubar & ;;
      install)   chanx-install & ;;
      close|*)   break ;;
    esac
  done
else
  printf 'chanxOS Welcome — Fitur tersedia:\n'
  printf '  chanx-info        System info\n'
  printf '  chanx-update      Update paket\n'
  printf '  chanx-devpack     DevPack installer\n'
  printf '  chanx-study-mode  Pomodoro timer\n'
  printf '  chanx-focus       Focus mode\n'
  printf '  chanx-hud         HUD overlay\n'
  printf '  chanx-glass       Glass level\n'
  printf '  chanx-theme       Theme switcher\n'
  printf '  chanx-install     Install ke disk\n'
fi
