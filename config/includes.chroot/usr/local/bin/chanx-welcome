#!/usr/bin/env bash
set -euo pipefail

show_text() {
  cat <<'TEXT'
Welcome to chanxOS 0.1 Alpha

Quick commands:
- chanx-info
- chanx-update
- chanx-clean
- chanx-devpack
- chanx-study-mode 25

Learning Hub:
~/ChanxOS-Learning
TEXT
}

open_terminal_cmd() {
  local cmd="$1"
  if command -v x-terminal-emulator >/dev/null 2>&1; then
    x-terminal-emulator -e bash -lc "$cmd; echo; read -p 'Press Enter to close...'"
  else
    bash -lc "$cmd"
  fi
}

if command -v python3 >/dev/null 2>&1 && python3 - <<'PYCHK' >/dev/null 2>&1
import gi
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk
PYCHK
then
  python3 <<'PYAPP'
import gi
import os
import subprocess
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk

CSS = b"""
window {
  background: linear-gradient(135deg, #eef8ff, #bfeaff);
}
#shell {
  background: rgba(255,255,255,0.42);
  border-radius: 28px;
  border: 1px solid rgba(255,255,255,0.80);
  padding: 24px;
}
#title {
  font-size: 34px;
  font-weight: 800;
  color: #16324A;
}
#subtitle {
  font-size: 14px;
  color: #426D85;
}
.card {
  background: rgba(255,255,255,0.54);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.86);
  padding: 16px;
  box-shadow: 0 18px 40px rgba(59,123,158,0.16);
}
.card-title {
  font-size: 16px;
  font-weight: 700;
  color: #173047;
}
.card-desc {
  font-size: 12px;
  color: #557A91;
}
button {
  border-radius: 16px;
  padding: 10px 14px;
  background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(222,246,255,0.74));
  border: 1px solid rgba(255,255,255,0.96);
  color: #16324A;
  font-weight: 700;
}
button:hover {
  background: linear-gradient(135deg, #ffffff, #d6f5ff);
}
.suggested-action {
  background: linear-gradient(135deg, #8BE6FF, #2AAEE8);
  color: white;
}
"""

def run(cmd):
    try:
        subprocess.Popen(cmd, shell=True)
    except Exception as exc:
        dialog = Gtk.MessageDialog(message_type=Gtk.MessageType.ERROR, buttons=Gtk.ButtonsType.OK, text=str(exc))
        dialog.run()
        dialog.destroy()

def terminal(cmd):
    run(f"x-terminal-emulator -e bash -lc \"{cmd}; echo; read -p 'Press Enter to close...'\"")

class App(Gtk.Window):
    def __init__(self):
        super().__init__(title="chanxOS Welcome Center")
        self.set_default_size(820, 520)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_name("window")
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        shell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        shell.set_name("shell")
        shell.set_margin_top(22); shell.set_margin_bottom(22); shell.set_margin_start(22); shell.set_margin_end(22)
        self.add(shell)

        title = Gtk.Label(label="chanxOS")
        title.set_xalign(0); title.set_name("title")
        subtitle = Gtk.Label(label="Clean Linux for learning, coding, and building — with a calm liquid glass workspace.")
        subtitle.set_xalign(0); subtitle.set_name("subtitle")
        shell.pack_start(title, False, False, 0)
        shell.pack_start(subtitle, False, False, 0)

        grid = Gtk.Grid(column_spacing=16, row_spacing=16)
        shell.pack_start(grid, True, True, 0)

        cards = [
            ("System Info", "See OS, kernel, and machine summary.", lambda *_: terminal("chanx-info")),
            ("Update System", "Refresh package metadata and upgrades.", lambda *_: terminal("chanx-update")),
            ("DevPack", "Install coding packs for web/backend/student workflow.", lambda *_: run("chanx-devpack")),
            ("Study Mode", "Start a 25-minute focus timer.", lambda *_: terminal("chanx-study-mode 25")),
            ("Learning Hub", "Open built-in Linux and developer notes.", lambda *_: run("xdg-open ~/ChanxOS-Learning")),
            ("Terminal", "Open a clean terminal session.", lambda *_: run("x-terminal-emulator")),
        ]

        for i, (name, desc, cb) in enumerate(cards):
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            card.get_style_context().add_class("card")
            card.set_size_request(240, 130)
            t = Gtk.Label(label=name); t.set_xalign(0); t.set_name("card-title")
            d = Gtk.Label(label=desc); d.set_xalign(0); d.set_line_wrap(True); d.set_name("card-desc")
            b = Gtk.Button(label="Open")
            if i == 0:
                b.get_style_context().add_class("suggested-action")
            b.connect("clicked", cb)
            card.pack_start(t, False, False, 0)
            card.pack_start(d, True, True, 0)
            card.pack_start(b, False, False, 0)
            grid.attach(card, i % 3, i // 3, 1, 1)

win = App()
win.connect("destroy", Gtk.main_quit)
win.show_all()
Gtk.main()
PYAPP
elif command -v zenity >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
  while true; do
    CHOICE=$(zenity --list \
      --title="Welcome to chanxOS" \
      --text="chanxOS 0.1 Alpha — Simple Linux for learning, coding, and building." \
      --column="Menu" --column="Action" \
      "System Info" "Show chanxOS system information" \
      "Update System" "Run apt update and upgrade" \
      "DevPack Installer" "Install developer packages" \
      "Study Mode" "Start 25-minute focus timer" \
      "Learning Hub" "Open learning folder" \
      "Close" "Exit welcome center" \
      --width=720 --height=380) || exit 0

    case "$CHOICE" in
      "System Info") open_terminal_cmd "chanx-info" ;;
      "Update System") open_terminal_cmd "chanx-update" ;;
      "DevPack Installer") chanx-devpack ;;
      "Study Mode") open_terminal_cmd "chanx-study-mode 25" ;;
      "Learning Hub") xdg-open "$HOME/ChanxOS-Learning" >/dev/null 2>&1 || true ;;
      "Close") exit 0 ;;
    esac
  done
else
  show_text
fi
